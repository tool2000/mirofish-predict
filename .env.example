# ===== LLM 설정 (llama.cpp OpenAI 호환 서버) =====
# 로컬 llama.cpp 서버를 사용합니다.
# 서버 시작: llama-server -m model.gguf --port 8080 --cache-type-k f16 --cache-type-v f16
LLM_API_KEY=not-needed
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL_NAME=local-model

# ===== kg-gen 설정 (지식 그래프 추출) =====
# 동일한 llama.cpp 서버를 사용합니다 (LiteLLM 포맷)
KGGEN_MODEL=openai/local-model

# ===== Kuzu DB 설정 (선택) =====
# 기본값: backend/data/kuzu_db
# KUZU_DB_DIR=backend/data/kuzu_db

# ===== 시뮬레이션 최적화 설정 (선택) =====
# 수렴 조기종료: KL-divergence가 임계값 이하면 시뮬레이션 종료
# CONVERGENCE_THRESHOLD=0.05
# CONVERGENCE_CHECK_INTERVAL=5
